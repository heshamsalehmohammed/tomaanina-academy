# PostgreSQL connection (use pooled URL for Vercel/serverless)
DATABASE_URL="postgresql://user:password@host:5432/tomaanina?schema=public"

# Auth.js secret (generate: openssl rand -base64 32)
AUTH_SECRET="your-secret-at-least-32-characters-long"

# Admin seed credentials (used by: npm run db:seed)
ADMIN_SEED_EMAIL="admin@tomaanina.com"
ADMIN_SEED_PASSWORD="ChangeMe123!"

# Public app config
NEXT_PUBLIC_APP_NAME="أكاديمية الطمأنينة"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
